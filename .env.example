# ---- FREE (no key required) ----
# Hacker News and DuckDuckGo work with no config. Just run:
#   python run.py "Product" --sources hackernews,duckduckgo

# ---- Reddit (free app at https://www.reddit.com/prefs/apps) ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ProductSentimentCrawler/1.0

# ---- Optional: Web search (surfaces Reddit, LinkedIn, etc. in results) ----
# Brave: https://brave.com/search/api/ (free credits monthly)
BRAVE_API_KEY=
# SerpAPI: https://serpapi.com/ (free tier)
SERPAPI_KEY=

# ---- Limits (per-source) ----
REDDIT_SEARCH_LIMIT=200
WEB_SEARCH_LIMIT=50
HN_SEARCH_LIMIT=100
DUCKDUCKGO_LIMIT=50

# ---- Optional: File cache (avoid re-fetching; set to a directory path) ----
CACHE_DIR=
CACHE_MAX_AGE=3600
